          </tr>
          <tr>
            <td>PEC assistito</td>
            <td>Indirizzo PEC dell'assistito</td>
            <td>Patient</td>
            <td>Patient.telecom.where(system='email').where(use='work' or extension.exists())</td>
          </tr>
